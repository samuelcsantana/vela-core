# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string (e.g. from Neon: https://neon.tech)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Secret used to sign JWTs. Use a long, random value in production.
JWT_SECRET="replace-with-a-long-random-secret"

# AWS S3 credentials, required for tenant logo uploads (POST/PATCH /api/tenants).
# The bucket must grant public read via a bucket policy - do not rely on
# object ACLs, since buckets created since April 2023 default to
# "Bucket owner enforced" object ownership, which disables ACLs entirely.
AWS_REGION="sa-east-1"
AWS_ACCESS_KEY_ID="replace-with-your-access-key-id"
AWS_SECRET_ACCESS_KEY="replace-with-your-secret-access-key"
AWS_S3_BUCKET_NAME="replace-with-your-bucket-name"

# Required when NODE_ENV=production - the app refuses to start in production
# without it. The exact frontend origin(s) allowed to call this API with
# credentials, comma-separated for more than one (e.g. a Vercel production
# URL plus a staging/preview URL).
FRONTEND_URL="https://app.your-domain.com"

# development | production. Controls the token cookie's Secure/SameSite
# flags and CORS origin resolution - see README for details. Treated as
# development when unset.
NODE_ENV="development"

# Port to listen on. Cloud platforms (e.g. Render) set this dynamically at
# deploy time; falls back to 3333 for local development.
PORT=3333
