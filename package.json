{
  "name": "vela-core",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS backend with tenant-scoped data isolation, JWT auth and RBAC, built on Fastify + Prisma",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "prisma generate",
    "prepare": "husky || true",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\" \"*.config.ts\"",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "*": "secretlint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samuelcsantana/vela-core.git"
  },
  "keywords": [
    "multi-tenant",
    "saas",
    "fastify",
    "prisma",
    "rbac",
    "typescript"
  ],
  "author": "Samuel Santana",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/samuelcsantana/vela-core/issues"
  },
  "homepage": "https://github.com/samuelcsantana/vela-core#readme",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1078.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "fastify-plugin": "^6.0.0",
    "fastify-type-provider-zod": "^7.0.0",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "form-data": "^4.0.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "secretlint": "^13.0.2",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.9"
  }
}
